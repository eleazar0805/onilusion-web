# Configuración SMTP para el formulario de contacto (solo servidor, nunca expuesta al navegador).
# Sin estas variables, la API registra la solicitud en logs y responde OK (modo desarrollo).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Web Onilusion <no-reply@onilusion.com>"
CONTACT_TO=info@onilusion.com
